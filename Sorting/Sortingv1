public class Merge : ISortable
{
    public void Sort(int[] arr)
    {
   if ( arr.Length <= 1)
    return;
   
    int mid = arr.Length / 2; 
    int[] arr1 = new int[mid];
    int[] arr2= new int[arr.Length - mid];

     for (int i = 0; i < mid; i++)
       {
       arr1[i] = arr[i];
       }       
     for (int i = mid; i < arr.Length; i++)
     {
      arr2[i - mid] = arr[i];
     }
         
        Sort(arr1);
        Sort(arr2);

        MergeArrays(arr, arr1, arr2);
    }

    private void MergeArrays(int[] arr, int[] arr1, int[] arr2)
    {
        int i = 0; // index for arr1
        int j = 0; // index for arr2
        int k = 0; // index for arr

        while (i < arr1.Length && j < arr2.Length)
        {
            if (arr1[i] <= arr2[j])
                arr[k++] = arr1[i++];
            else
                arr[k++] = arr2[j++];
        }

        while (i < arr1.Length)
            arr[k++] = arr1[i++];

        while (j < arr2.Length)
            arr[k++] = arr2[j++];
    }
}


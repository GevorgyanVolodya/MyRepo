public class BubleSort : ISortable
{

    public void Sort(int[] arr)
    {
    for (int j=0; j< arr.Length-1;j++)
        for (int i = 0; i < arr.Length-1-j; i++)
        {
            if (arr[i] > arr[i + 1])
            {
                int temp = arr[i];
                arr[i] = arr[i+1];
                arr[i+1] = temp;
            }
        }
    }

}



public class Insertion : ISortable
{
 public void Sort(int[] arr)
    {
   for (int i=0;i<arr.Length;i++)
     {
      int key=arr[i];
      int j=i-1;
      while(j>=0 && key<arr[j])
     {
       arr[j+1]= arr[j];
       j=j-1;
       arr[j+1]=key; 

     }
    }
    }
}





     int PivotIndex=i+1;
     Sort(arr,low,PivotIndex-1);
     Sort(arr,PivotIndex+1,high);
    }
 }



public class Average : ISortable
{
    
public void Sort(int [] arr)
    {
	int sum=0,n=arr.Length;
      for (int i = 0; i < arr.Length; i++)
        {
          sum += arr[i];
        }     
      int plan = sum/n;
      for(int i=0; i < arr.Length;i++)
        {
            arr[i]=plan;
        }

    }
}



